{
  "name": "@simplyprint/n8n-nodes-simplyprint",
  "version": "0.4.0",
  "description": "n8n community node for SimplyPrint - monitor 3D printer fleets, manage queues, automate print jobs.",
  "keywords": [
    "n8n-community-node-package",
    "simplyprint",
    "3d-printing",
    "automation",
    "print-farm"
  ],
  "license": "MIT",
  "homepage": "https://simplyprint.io/integrations/n8n",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SimplyPrint/n8n-nodes-simplyprint.git"
  },
  "bugs": {
    "url": "https://github.com/SimplyPrint/n8n-nodes-simplyprint/issues"
  },
  "author": {
    "name": "SimplyPrint",
    "email": "contact@simplyprint.io",
    "url": "https://simplyprint.io"
  },
  "engines": {
    "node": ">=20.15"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "format": "prettier nodes credentials --write",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/SimplyPrintOAuth2Api.credentials.js",
      "dist/credentials/SimplyPrintApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/SimplyPrint/SimplyPrint.node.js",
      "dist/nodes/SimplyPrintTrigger/SimplyPrintTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.23.0",
    "@types/node": "^20.12.7",
    "eslint": "^9.39.0",
    "n8n-workflow": "^1.82.0",
    "prettier": "^3.3.2",
    "release-it": "^20.0.1",
    "typescript": "~5.4.5",
    "vitest": "^1.6.1"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.82.0"
  }
}
